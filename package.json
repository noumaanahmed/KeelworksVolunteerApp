{
  "name": "keelworks-volunteer-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/applicant-portal",
    "apps/admin-portal",
    "apps/api",
    "packages/shared-ui"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace apps/api",
    "dev:applicant": "npm start --workspace apps/applicant-portal",
    "dev:admin": "npm start --workspace apps/admin-portal",
    "build:applicant": "npm run build --workspace apps/applicant-portal",
    "build:admin": "npm run build --workspace apps/admin-portal",
    "check:api": "npm run check --workspace apps/api",
    "check": "npm run check:api",
    "install:all": "npm install",
    "start:api": "npm run start --workspace apps/api",
    "build:applicant:netlify": "npm run build:applicant",
    "build:admin:netlify": "npm run build:admin",
    "deploy:check": "npm run check:api && npm run build:applicant && npm run build:admin"
  },
  "engines": {
    "node": ">=20 <23",
    "npm": ">=9"
  }
}

# Railway API service variables
# Use either DATABASE_URL/MYSQL_URL or the individual MySQL variables.

NODE_ENV=production

# Option A: Railway connection URL
DATABASE_URL=mysql://USER:PASSWORD@HOST:PORT/DATABASE

# Option B: Railway MySQL variables. Railway may create these automatically.
# MYSQLDATABASE=railway
# MYSQLUSER=root
# MYSQLPASSWORD=...
# MYSQLHOST=...
# MYSQLPORT=3306

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=8h
ADMIN_SIGNUP_SECRET=replace_with_a_private_admin_signup_key

# Replace with your final Netlify URLs after both sites are created.
CORS_ORIGIN=https://your-applicant-site.netlify.app,https://your-admin-site.netlify.app

# Optional Gmail confirmation email
EMAIL_USER=
EMAIL_APP_PASSWORD=

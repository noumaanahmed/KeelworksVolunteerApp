# Local API environment example
# Copy this file to apps/api/.env for local development.
# Do NOT commit apps/api/.env.

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3001,http://localhost:3002

# Local MySQL
# For Railway production, use deploy/railway-api.env.example as the checklist instead.
MYSQL_DB_NAME=volunteer_management
MYSQL_USERNAME=root
MYSQL_PASSWORD=
MYSQL_HOST=localhost
MYSQL_PORT=3306

# Auth
JWT_SECRET=keelworks_jwt_secret_2024
# JWT_EXPIRES_IN=8h
ADMIN_SIGNUP_SECRET=keelworks-admin-2024

# Optional Gmail confirmation email
EMAIL_USER=
EMAIL_APP_PASSWORD=
